{
	"name": "@spences10/pi-sqlite-tools",
	"version": "0.0.8",
	"description": "Pi extension that reminds the model to prefer mcp-sqlite-tools for SQLite database work",
	"keywords": [
		"database",
		"mcp",
		"pi",
		"pi-package",
		"sqlite"
	],
	"homepage": "https://github.com/spences10/my-pi/tree/main/packages/pi-sqlite-tools#readme",
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git",
		"directory": "packages/pi-sqlite-tools"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self",
		"build:self": "tsc -p tsconfig.build.json",
		"check": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run check:self",
		"check:self": "tsc --noEmit -p tsconfig.json",
		"test": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run test:self",
		"test:self": "vitest run"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"engines": {
		"node": ">=24.15.0"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		],
		"image": "https://raw.githubusercontent.com/spences10/my-pi/main/assets/pi-package-preview.png"
	}
}
