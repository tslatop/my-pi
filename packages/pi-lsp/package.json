{
	"name": "@spences10/pi-lsp",
	"version": "0.0.14",
	"description": "Pi extension that exposes Language Server Protocol diagnostics, hover, definition, and reference tools",
	"keywords": [
		"language-server",
		"lsp",
		"pi",
		"pi-package"
	],
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git",
		"directory": "packages/pi-lsp"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self",
		"build:self": "tsc -p tsconfig.build.json",
		"check": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run check:self",
		"check:self": "tsc --noEmit -p tsconfig.json",
		"test": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run test:self",
		"test:self": "vitest run"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "^0.73.0",
		"@spences10/pi-child-env": "workspace:*",
		"@spences10/pi-project-trust": "workspace:*",
		"@spences10/pi-tui-modal": "workspace:*",
		"typebox": "^1.1.37"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=24.15.0"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	}
}
