{
	"name": "@spences10/pi-telemetry",
	"version": "0.0.17",
	"description": "Pi extension for local SQLite telemetry of runs, turns, tools, and provider requests",
	"keywords": [
		"evals",
		"pi",
		"pi-package",
		"sqlite",
		"telemetry"
	],
	"homepage": "https://github.com/spences10/my-pi/tree/main/packages/pi-telemetry#readme",
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git",
		"directory": "packages/pi-telemetry"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self",
		"build:self": "tsc -p tsconfig.build.json && cp src/schema.sql dist/schema.sql",
		"check": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run check:self",
		"check:self": "tsc --noEmit -p tsconfig.json",
		"test": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run test:self",
		"test:self": "vitest run",
		"coverage:self": "vitest run --coverage",
		"coverage": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run coverage:self"
	},
	"dependencies": {
		"@spences10/pi-tui-modal": "workspace:*"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "catalog:",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"engines": {
		"node": ">=24.15.0"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		],
		"image": "https://raw.githubusercontent.com/spences10/my-pi/main/assets/pi-package-preview.png"
	}
}
