{
	"name": "@spences10/pi-context",
	"version": "0.0.14",
	"description": "Pi extension for local SQLite context sidecar storage and retrieval of large tool output",
	"keywords": [
		"context",
		"evals",
		"fts5",
		"pi",
		"pi-package",
		"sqlite"
	],
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git",
		"directory": "packages/pi-context"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./store": {
			"types": "./dist/store.d.ts",
			"import": "./dist/store.js"
		}
	},
	"scripts": {
		"build": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self",
		"build:self": "tsc -p tsconfig.build.json && cp src/schema.sql dist/schema.sql",
		"check": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run check:self",
		"check:self": "tsc --noEmit",
		"test": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self && pnpm run test:self",
		"test:self": "vitest run"
	},
	"dependencies": {
		"@spences10/pi-redact": "workspace:*",
		"@spences10/pi-tui-modal": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"engines": {
		"node": ">=24.15.0"
	},
	"pi": {
		"extensions": [
			"./dist/index.js"
		]
	}
}
