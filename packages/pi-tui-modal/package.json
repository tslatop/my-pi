{
	"name": "@spences10/pi-tui-modal",
	"version": "0.0.8",
	"description": "Shared Pi TUI modal helpers for picker and settings overlays",
	"keywords": [
		"modal",
		"pi",
		"picker",
		"tui"
	],
	"license": "MIT",
	"author": "Scott Spence <me@scottspence.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git",
		"directory": "packages/pi-tui-modal"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run build:self",
		"build:self": "tsc -p tsconfig.build.json",
		"check": "pnpm --filter \"$npm_package_name^...\" run build:self && pnpm run check:self",
		"check:self": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "^0.73.0",
		"@mariozechner/pi-tui": "^0.73.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=24.15.0"
	}
}
