{
	"name": "web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp exec vite dev",
		"build": "wrangler types && vp exec vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"prepare": "vp exec svelte-kit sync || echo ''",
		"check": "wrangler types --include-env=false --check && vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "vp exec svelte-kit sync && vp exec svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "oxfmt --check \"**/*.svelte\"",
		"format": "oxfmt \"**/*.svelte\"",
		"test:unit": "vp exec vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "vp exec playwright install && vp exec playwright test",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@fontsource-variable/victor-mono": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "catalog:",
		"@vitest/browser-playwright": "^4.1.6",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"oxfmt": "^0.52.0",
		"phosphor-svelte": "^3.1.0",
		"playwright": "^1.60.0",
		"shadcn-svelte": "^1.2.7",
		"svead": "^0.0.15",
		"svelte": "^5.55.8",
		"svelte-check": "^4.4.8",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "catalog:",
		"vite": "^8.0.13",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.92.0"
	}
}
