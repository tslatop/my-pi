{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"minimumReleaseAge": "2 days",
	"packageRules": [
		{
			"description": "Keep Pi packages aligned across workspace packages",
			"matchManagers": ["npm"],
			"matchPackageNames": ["/^@mariozechner\\//"],
			"groupName": "Pi packages",
			"groupSlug": "mariozechner-pi"
		},
		{
			"description": "Do not open PRs for temporary/security pins in pnpm-workspace overrides",
			"matchManagers": ["npm"],
			"matchFileNames": ["pnpm-workspace.yaml"],
			"matchDepTypes": ["pnpm-workspace.overrides"],
			"enabled": false
		}
	]
}
